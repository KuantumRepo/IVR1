# ==========================================
# Broadcaster Environment Configuration
# ==========================================

# ── Web Proxy & Domain ────────────────────
# The public domain name where the app is hosted (e.g., app.domain.com). 
# This tells Caddy what domain to acquire an SSL certificate for.
DOMAIN_NAME=localhost

# ── Database & Redis ──────────────────────
# In the Docker stack, these default to the internal container hostnames.
# The install.sh script will generate secure passwords automatically for production.
DB_PASSWORD=broadcaster_secret
DATABASE_URL=postgresql+asyncpg://broadcaster:${DB_PASSWORD}@postgres/broadcaster
REDIS_URL=redis://redis:6379

# ── FreeSWITCH ESL (Internal Management) ──
# This is how the Backend communicates with FreeSWITCH.
# In the full Docker stack, the host is the 'freeswitch' container.
FS_ESL_HOST=freeswitch
FS_ESL_PORT=8021
FS_ESL_PASSWORD=ClueCon

# ── FreeSWITCH SIP (Agent Registration) ───
# CRITICAL: This is the public-facing IP or Domain where agents connect their softphones.
# Unlike HTTPS which goes through Caddy, SIP and RTP are UDP protocols that go
# DIRECTLY to the FreeSWITCH container on ports 5060 and 16384-16400.
# 
# For Local Dev: Leave as 127.0.0.1
# For Production: Change to your server's Public IP or an A-record domain (e.g. sip.mydomain.com)
FS_SIP_DOMAIN=127.0.0.1
FS_SIP_PORT=5060

# ── FreeSWITCH Public IP Discovery ────────
# By default we use stun.freeswitch.org to figure out our public IP for NAT traversal.
# You can hardcode your server's public IP here if STUN fails or is slow.
EXT_SIP_IP=stun:stun.freeswitch.org
EXT_RTP_IP=stun:stun.freeswitch.org
