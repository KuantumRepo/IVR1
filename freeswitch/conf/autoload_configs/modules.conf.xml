<configuration name="modules.conf" description="Modules">
  <!-- ═══════════════════════════════════════════════════════════════════════
       Broadcaster-Optimized Module List (19 modules + 2 AMD)
       ═══════════════════════════════════════════════════════════════════════
       Stripped to only the modules actively invoked by our codebase:
       - Lua scripts (amd_orchestrator.lua)
       - Python ESL (handlers.py, dialer.py, connection.py)
       - XML dialplan / autoload configs
       
       Modules removed: mod_conference, mod_verto, mod_rtc, mod_voicemail,
       mod_fifo, mod_enum, mod_esf, mod_fsv, mod_valet_parking, mod_httapi,
       mod_dialplan_asterisk, mod_av, mod_png, mod_g723_1, mod_g729,
       mod_amr, mod_b64
       
       Result: ~40MB less RAM, 17 fewer failure points, lower context-switch
       overhead — critical for 500 concurrent calls with low jitter.
  ═══════════════════════════════════════════════════════════════════════ -->
  <modules>
    <!-- Logging -->
    <load module="mod_console"/>
    <load module="mod_logfile"/>

    <!-- Event Handlers -->
    <load module="mod_cdr_csv"/>
    <load module="mod_event_socket"/>

    <!-- Endpoints -->
    <load module="mod_sofia"/>
    <load module="mod_loopback"/>

    <!-- Core Applications -->
    <load module="mod_commands"/>
    <load module="mod_dptools"/>
    <load module="mod_callcenter"/>
    <load module="mod_db"/>
    <load module="mod_hash"/>

    <!-- Dialplan -->
    <load module="mod_dialplan_xml"/>

    <!-- Scripting -->
    <load module="mod_lua"/>

    <!-- Codecs -->
    <load module="mod_opus"/>

    <!-- File Formats -->
    <load module="mod_sndfile"/>
    <load module="mod_native_file"/>
    <load module="mod_local_stream"/>
    <load module="mod_tone_stream"/>

    <!-- Say (IVR number/date prompts) -->
    <load module="mod_say_en"/>

    <!-- AMD — Answering Machine Detection -->
    <!-- mod_amd: Layer 1 heuristic (compiled from seanbright/mod_amd source) -->
    <load module="mod_amd"/>
    <!-- mod_avmd: Layer 3 beep detector (built into FreeSWITCH) -->
    <load module="mod_avmd"/>

  </modules>
</configuration>
