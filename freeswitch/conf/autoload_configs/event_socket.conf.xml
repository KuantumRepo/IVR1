<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <param name="nat-map" value="false"/>
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="$${fs_esl_password}"/>
    <!-- Allow ESL connections from any IPv4 address (Docker bridge network) -->
    <!-- Password authentication is still enforced for security -->
    <param name="apply-inbound-acl" value="any_v4.auto"/>
    <!--<param name="stop-on-bind-error" value="false"/>-->
  </settings>
</configuration>
