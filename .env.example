# ==========================================
# Broadcaster Environment Configuration
# ==========================================
# This file is generated by install.sh for production deployments.
# For local development, the defaults below are sufficient.

# ── Web Proxy & Domain ────────────────────
# The public domain name where the app is hosted (e.g., app.domain.com).
# Caddy uses this to acquire an SSL certificate automatically.
DOMAIN_NAME=localhost

# ── Database & Redis ──────────────────────
# In the Docker stack, these default to the internal container hostnames.
# install.sh generates secure passwords for production.
DB_PASSWORD=broadcaster_secret
DATABASE_URL=postgresql+asyncpg://broadcaster:${DB_PASSWORD}@postgres/broadcaster
REDIS_URL=redis://redis:6379

# ── FreeSWITCH ESL (Internal Management) ──
# How the Backend communicates with FreeSWITCH.
# In the full Docker stack, FS runs on host network — connect via host.docker.internal.
FS_ESL_HOST=freeswitch
FS_ESL_PORT=8021
FS_ESL_PASSWORD=ClueCon

# ── FreeSWITCH SIP (Agent Registration) ───
# CRITICAL: This is the public-facing IP or Domain where agents connect their softphones.
# SIP and RTP are UDP protocols that go DIRECTLY to FreeSWITCH on the host network.
#
# Local Dev:   127.0.0.1
# Production:  Your server's Public IP or an A-record domain (e.g., sip.mydomain.com)
FS_SIP_DOMAIN=127.0.0.1
FS_SIP_PORT=5060

# ── FreeSWITCH Media IP (SDP) ────────────
# CRITICAL FOR PSTN: This IP is placed into the SDP of every outbound INVITE.
# PSTN carriers (Bitcall, etc.) send RTP voice and DTMF packets to this address.
#
# If this is wrong, you get one-way audio: the callee hears the IVR but
# their keypress (digit 1) never reaches FreeSWITCH. The DTMF debug handler
# will show zero events.
#
# Local Dev:   stun:stun.freeswitch.org  (auto-detect via STUN — works for SIP-to-SIP)
# Production:  YOUR VPS PUBLIC IP        (required for PSTN — carriers don't do NAT traversal)
#
# install.sh sets this automatically. If you're deploying manually:
#   1. Set EXT_RTP_IP and EXT_SIP_IP to your VPS public IPv4 address
#   2. Open UDP 16384-32768 on your firewall for inbound RTP
EXT_RTP_IP=stun:stun.freeswitch.org
EXT_SIP_IP=stun:stun.freeswitch.org
